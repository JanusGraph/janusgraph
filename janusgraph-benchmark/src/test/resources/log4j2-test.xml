<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="warn">
    <Appenders>
        <Console name="STDOUT" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} %-5level %class.%method{36} - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <!-- Surface the scan lifecycle/progress lines (start, 30s progress, completion) during
             long-running large-scale benchmark tests. -->
        <Logger name="org.janusgraph.diskstorage.keycolumnvalue.scan" level="info"/>
        <Root level="warn">
            <AppenderRef ref="STDOUT"/>
        </Root>
    </Loggers>
</Configuration>
